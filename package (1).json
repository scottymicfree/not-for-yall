{
  "name": "lucy-os-v5",
  "version": "5.0.0",
  "description": "Lucy OS v5 \u2014 137-node AGI Cognitive Mesh",
  "main": "electron/main.js",
  "type": "commonjs",
  "scripts": {
    "dev": "concurrently \"npm run vite\" \"npm run electron:dev\"",
    "vite": "vite --port 5173",
    "electron:dev": "wait-on http://localhost:5173 && cross-env NODE_ENV=development electron .",
    "build": "vite build",
    "electron:build": "npm run build && electron-builder",
    "dist": "npm run build && electron-builder --win --x64",
    "dist:mac": "npm run build && electron-builder --mac",
    "dist:linux": "npm run build && electron-builder --linux"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-globe.gl": "^2.27.0",
    "three": "^0.184.0",
    "lucide-react": "^0.400.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.0.0",
    "autoprefixer": "^10.4.0",
    "concurrently": "^8.2.0",
    "cross-env": "^7.0.3",
    "electron": "31",
    "electron-builder": "24",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.0.0",
    "vite": "^5.0.0",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "ai.ninjatech.lucyos",
    "productName": "Lucy OS",
    "copyright": "Lucy OS v5",
    "asar": true,
    "files": [
      "dist/**/*",
      "electron/**/*",
      "lucy-bridge/**/*",
      "assets/**/*"
    ],
    "extraResources": [
      {
        "from": "lucy-bridge",
        "to": "lucy-bridge",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.ico",
      "requestedExecutionLevel": "asInvoker"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "assets/icon.ico",
      "uninstallerIcon": "assets/icon.ico",
      "installerHeaderIcon": "assets/icon.ico",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Lucy OS"
    },
    "portable": {
      "artifactName": "LucyOS-${version}-portable.exe"
    },
    "mac": {
      "target": [
        {
          "target": "dmg"
        }
      ],
      "icon": "assets/icon.icns",
      "category": "public.app-category.developer-tools"
    },
    "linux": {
      "target": [
        {
          "target": "AppImage"
        }
      ],
      "icon": "assets/icon.png",
      "category": "Development"
    },
    "directories": {
      "output": "release"
    }
  },
  "author": "Lucy OS"
}